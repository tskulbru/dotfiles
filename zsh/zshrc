# Portable zsh config (oh-my-zsh + Powerlevel10k).
# Installed by install.sh. Put machine-specific PATH/exports in ~/.zshrc.local
# (sourced at the bottom) so this file stays in sync with the repo.

# Powerlevel10k instant prompt. Keep near the top.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"

zstyle ':omz:update' mode auto
zstyle ':omz:update' frequency 13

# zsh-autosuggestions and zsh-syntax-highlighting are installed by install.sh
# into $ZSH_CUSTOM/plugins. The rest ship with oh-my-zsh.
plugins=(
  git
  kubectl
  kubectx
  docker
  golang
  fzf
  z
  zsh-autosuggestions
  zsh-syntax-highlighting
)

source "$ZSH/oh-my-zsh.sh"

# Prompt config. Run `p10k configure` to regenerate, or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# Inside kitty, fall back to a TERM ssh hosts understand.
[[ "$TERM" == "xterm-kitty" ]] && alias ssh="TERM=xterm-256color ssh"

# Machine-specific overrides (PATH, SDKs, tool init). Not tracked by the repo.
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local
